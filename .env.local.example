# ------------------------------------------------------------------
# Budget App — variables d'environnement
# Copier ce fichier en `.env.local` et renseigner les valeurs.
# `.env.local` est ignoré par git (ne jamais committer les clés).
# ------------------------------------------------------------------

# Supabase — Project Settings > API
# URL du projet (ex : https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique "anon" (sûre côté navigateur, protégée par les politiques RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
